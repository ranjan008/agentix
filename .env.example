# ─── Phase 3: Scale additions ───────────────────────────────────────────────
# Voyage AI embeddings for vector memory (optional — falls back to hash embed)
# VOYAGE_API_KEY=pa-...

# OpenTelemetry collector endpoint (optional — disables tracing if unset)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_EXPORTER_CONSOLE=true   # print spans to stdout in dev

# ─── Phase 2: Security additions ────────────────────────────────────────────
# HMAC secret for audit log chain integrity verification
AUDIT_HMAC_SECRET=change-me-audit-secret

# ─── Standard tier (PostgreSQL + Redis) ─────────────────────────────────────
# DATABASE_URL=postgresql://agentix:password@localhost:5432/agentix
# REDIS_URL=redis://localhost:6379/0

# ─── HashiCorp Vault (Enterprise tier secrets backend) ───────────────────────
# VAULT_ADDR=http://vault:8200
# VAULT_TOKEN=...

# ─── AWS Secrets Manager (Enterprise tier secrets backend) ───────────────────
# AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ─── Required ───────────────────────────────────────────────────────────────
# Anthropic API key for LLM calls
ANTHROPIC_API_KEY=sk-ant-...

# ─── Auth (optional — only needed when security.enforce_rbac: true) ──────────
JWT_SECRET=change-me-in-production

# ─── Slack (optional — only needed when Slack channel is enabled) ─────────────
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# ─── Email (optional — only needed when email-composer skill sends mail) ──────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=...
SMTP_FROM=agent@example.com

# ─── Webhook HMAC (optional) ─────────────────────────────────────────────────
WEBHOOK_HMAC_SECRET=...

# ─── Agent runtime ───────────────────────────────────────────────────────────
AGENTIX_AGENTS_DIR=agents
AGENTIX_WORKDIR=data/workdir
